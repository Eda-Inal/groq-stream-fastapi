# ── Groq ─────────────────────────────────────────────────────────────
# Kayıt: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ── OpenRouter ────────────────────────────────────────────────────────
# Kayıt: https://openrouter.ai  →  Keys
# Ücretsiz: meta-llama/llama-3.3-70b-instruct:free, google/gemma-4-31b-it:free,
#           nvidia/nemotron-3-super-120b-a12b:free, openai/gpt-oss-120b:free
# Ücretli:  google/gemini-2.5-flash, google/gemini-2.5-pro, google/gemini-3.1-pro-preview,
#           meta-llama/llama-4-maverick, anthropic/claude-3.5-haiku,
#           anthropic/claude-sonnet-4, openai/gpt-4o-mini
OPENROUTER_API_KEY=

# ── Google Gemini (Direct API) ────────────────────────────────────────
# Kayıt: https://aistudio.google.com/app/apikey
# Modeller: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-flash,
#           gemini-2.5-pro, gemini-3-flash-preview, gemini-3.1-pro-preview
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# ── Tavily Web Search ─────────────────────────────────────────────────
TAVILY_API_KEY=

# ── MCP ───────────────────────────────────────────────────────────────
MCP_ENABLED=true
MCP_SERVER_URL=http://mcp:8001

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama-local
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_TIMEOUT=30.0
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BACKOFF=1.5
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_MAX_ENTRIES=1000

# ── RAG / Chunking ────────────────────────────────────────────────────
RAG_SIMILARITY_THRESHOLD=0.65
RAG_DEFAULT_TOP_K=8
MAX_CONTEXT_TOKENS=12000
RAG_TOOL_MAX_CONTEXT_TOKENS=4000
CHUNK_SIZE_TOKENS=150
CHUNK_OVERLAP_TOKENS=30

# ── Tool flags ────────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=false
CALCULATOR_ENABLED=false
