# --- Groq (required) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Must match a key in app.core.config.AVAILABLE_MODELS
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# --- Database (required) ---
# Docker Compose: hostname `db`. From host: use `localhost`
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# --- Tavily (optional; web_search tool) ---
TAVILY_API_KEY=

# --- MCP (optional; remote tools) ---
# pydantic-settings accepts MCP_ENABLED / mcp_enabled (case-insensitive on most setups)
MCP_ENABLED=false
MCP_SERVER_URL=http://mcp:8001
# MCP_TIMEOUT=10.0

# --- Embeddings (Ollama local, active example) ---
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama-local
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_TIMEOUT=30.0
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BACKOFF=1.5
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_MAX_ENTRIES=1000

# --- RAG retrieval defaults ---
# RAG_DEFAULT_TOP_K=5
# RAG_SIMILARITY_THRESHOLD=0.7
# RAG_MAX_TOP_K=20
# RAG_SYSTEM_PROMPT_ENABLED=true
# MAX_CONTEXT_TOKENS=6000
# RESPONSE_RESERVE_TOKENS=1000
# RAG_TOOL_MAX_CONTEXT_TOKENS=2500

# --- Optional: RAG document chunking ---
# CHUNK_SIZE_TOKENS=500
# CHUNK_OVERLAP_TOKENS=100
# MAX_DOCUMENT_TOKENS=100000
# SHORT_DOC_SINGLE_CHUNK_MAX_TOKENS=100
# MIN_CHUNK_TOKENS=20
